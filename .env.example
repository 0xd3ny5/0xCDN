# Role
# Which component to start: origin | edge | router | management
CDN_ROLE=edge

# Common
CDN_HOST=0.0.0.0
CDN_PORT=8000

# Origin Server
CDN_ASSETS_DIR=./assets

# Edge Node
CDN_EDGE_ID=edge-1
CDN_EDGE_REGION=eu
CDN_ORIGIN_URL=http://localhost:8000
# CDN_SHIELD_URL=               # optional origin-shield URL

# Cache
CDN_CACHE_MAX_SIZE_BYTES=104857600   # 100 MB
CDN_CACHE_DEFAULT_TTL=3600           # 1 hour
CDN_CACHE_HOT_TIER_MAX_ITEMS=1000
CDN_CACHE_COLD_TIER_PATH=/tmp/cdn_cold

# Authentication
CDN_AUTH_SECRET_KEY=change-me-in-production
CDN_AUTH_TOKEN_TTL=3600

# Router / Load Balancer
# Format: id:host:port:region (comma-separated)
CDN_ROUTER_EDGES=edge-eu:edge-eu:8001:eu,edge-us:edge-us:8002:us,edge-asia:edge-asia:8003:asia
CDN_HEALTH_CHECK_INTERVAL=5
CDN_HEALTH_CHECK_TIMEOUT=1
CDN_HEALTH_MAX_FAILURES=3

# Management API
CDN_MGMT_EDGE_URLS=http://edge-eu:8001,http://edge-us:8002,http://edge-asia:8003
